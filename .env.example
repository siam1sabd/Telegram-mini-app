# ============================================================
# Content Vault — Telegram Mini App Environment Variables
# Copy this file to `.env` and fill in your values.
# ============================================================

# ---- Database (choose ONE mode) ----
# Local SQLite (development):
DATABASE_URL=file:./db/custom.db

# Turso (production) — get these from https://turso.tech
# 1. Install turso CLI: `brew install tursodatabase/tap/turso`
# 2. `turso db create content-vault`
# 3. `turso db tokens create content-vault`
# 4. `turso db show content-vault --url`  → put as TURSO_DATABASE_URL
# 5. Set TURSO_AUTH_TOKEN to the token from step 3
#TURSO_DATABASE_URL=libsql://content-vault-<your-account>.turso.io
#TURSO_AUTH_TOKEN=eyJhbGciOiJFZERTQSIsInR5cCI6IkpXVCJ9....

# ---- Telegram Bot ----
# 1. Create a bot with @BotFather
# 2. /newbot → get the token → put as TELEGRAM_BOT_TOKEN
# 3. /newapp (or via @BotFather menu) → set the Web App URL to your deployment
# 4. Set TELEGRAM_BOT_USERNAME to the bot's @username (without @)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=YourMiniAppBot

# ---- Admin Authentication ----
# First-time admin login uses these credentials.
# After the first login, the password is hashed and stored in the database.
# You can change it later by updating the database directly.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# A secret key used to sign admin session cookies. Generate with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=change-me-to-a-long-random-hex-string

# ---- Telegram Auth Strictness ----
# By default (lenient mode), the app lets users in even if the Telegram initData
# hash doesn't match your bot token. This prevents lockouts from:
#   - TELEGRAM_BOT_TOKEN typos / mismatched bots
#   - Third-party Telegram clients (Nagram, Plus, etc.) that don't sign initData
#   - Clock skew on the server
# Set STRICT_AUTH=true to enforce strict HMAC validation (recommended only for
# high-security production deployments after you've verified everything works).
STRICT_AUTH=false

# ---- AdsGram (optional but recommended for monetization) ----
# 1. Sign up at https://adsgram.ai
# 2. Create a new placement → copy the Block ID
# 3. Set it here OR manage from the Admin Panel → Settings
ADSGRAM_PLACEMENT_ID=

# ---- App Behavior (overridable from Admin Panel) ----
# These are seeded into the database on first run.
JOIN_BONUS=20
REFERRAL_REWARD=30
DOWNLOAD_POINT_COST=4
REQUIRED_AD_COUNT=2
